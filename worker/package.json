{
  "name": "@capown/worker-next",
  "version": "0.1.0",
  "description": "Next-generation CapOwn Worker (TypeScript) with claim-based jobs.",
  "private": true,
  "type": "module",
  "main": "dist/src/cli.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node dist/src/cli.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "pretest": "node -e \"\" || exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/server-filesystem": "2026.7.10",
    "toml": "^3.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
