{
  "name": "@capown/worker",
  "version": "0.1.0",
  "description": "CapOwn Worker (TypeScript) with claim-based jobs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/cli.js",
  "bin": {
    "capown-worker": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "config.toml.example",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node dist/src/cli.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm test",
    "prebuild": "npm run version:sync",
    "predev": "npm run version:sync",
    "pretest": "npm run version:sync",
    "pretypecheck": "npm run version:sync",
    "typecheck": "tsc --noEmit",
    "version:sync": "node ./scripts/sync-version.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/server-filesystem": "2026.7.10",
    "toml": "^3.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
